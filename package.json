{
  "name": "site-doctor",
  "version": "0.5.0",
  "description": "Audit rendered websites for broken links, images, accessibility, SEO, security headers, and more. CLI + MCP server for AI agents.",
  "type": "module",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "import": "./dist/audit/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "bin": {
    "site-doctor": "dist/cli.js",
    "site-doctor-mcp": "dist/mcp/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm build",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "audit",
    "website-audit",
    "broken-links",
    "accessibility",
    "a11y",
    "wcag",
    "seo",
    "security-headers",
    "mixed-content",
    "hydration",
    "nextjs",
    "react",
    "playwright",
    "axe-core",
    "cli",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subhro-kar/site-doctor.git"
  },
  "homepage": "https://github.com/subhro-kar/site-doctor#readme",
  "bugs": {
    "url": "https://github.com/subhro-kar/site-doctor/issues"
  },
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "@axe-core/playwright": "4.10.1",
    "@clack/prompts": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "13.1.0",
    "open": "10.2.0",
    "playwright": "1.52.0",
    "undici": "7.8.0",
    "zod": "3.25.73"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "22.15.16",
    "semantic-release": "^25.0.5",
    "typescript": "5.8.3"
  }
}
